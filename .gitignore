# OS cruft
.DS_Store

# Claude Code runtime state (per-repo marker dir, session sentinels)
.claude/
.sessions/

# Harness-neutral per-checkout project marker (local pin; never committed)
.agents/memory-project

# Python bytecode / virtualenvs
__pycache__/
*.pyc
.venv/

# ── Personal memory content: ship templates, ignore the real data ──

# Real index is regenerated from frontmatter; ship templates/index.template.md only
/index.md

# Derived on-demand "In Flight" snapshot (scripts/regenerate-state.sh) — a
# projection of every project's goals; regenerated, never authored, personal.
/state.md
/activity.md

# Real cross-project knowledge; ship domain/_template.md only.
# Exceptions: tooling domains carry no client data and apply to every instance
# of this memory system, so they are tracked.
/domain/*
!/domain/_template.md
!/domain/agent-tooling.md
!/domain/codex.md

# Real engagement memory; ship projects/_template/ only
/projects/*
!/projects/_template

# The ai-memory meta-project documents THIS repo (no client data) — track its
# durable artifacts AND its archive (past work stays visible in git; the memory
# system just never loads archive/). Only the volatile live scratch is local.
!/projects/ai-memory
# working.md and its per-worktree overlays (working.<key>.md) are volatile local
# scratch — never tracked, even for the meta-project.
/projects/ai-memory/working*.md

# ...except rolled working-memory snapshots. working.md is deliberately local, so
# archiving it must not be the back door that publishes it: a snapshot is raw
# session scratch (real names, client paths, half-formed threads) that never went
# through the redaction a wiki or memory.md entry gets. Keep .gitkeep so the dir
# still scaffolds for lint-memory.sh and the test fixtures.
/projects/ai-memory/archive/working/*
!/projects/ai-memory/archive/working/.gitkeep

# Task backlog and archived artifacts are personal
/tasks/
/archive/

# Superpowers brainstorm specs / plans are personal working docs (not published)
/docs/superpowers/

# One-shot system overview generated for external review — local, not published
/docs/system-overview.md

# Per-environment overrides (secrets/paths) — ship templates/config.local.sh.example only
/config.local.sh

# Machine-written migration high-water mark for sync-system.sh.
/.applied-version

# Instance-local executor deny-list overlay. Tracked defaults live in
# scripts/deny-list.txt; local entries are additive-only.
/scripts/deny-list.local.txt

# Per-instance remote-skill choices — ship templates/skills.toml.example as the
# tracked catalog, then copy/prune it locally as skills.toml. No negation needed:
# this rule is root-anchored, so the templates/ copy was never in scope.
/skills.toml

# Per-instance authored skills. The whole folder is ignored by one line — drop a
# skill dir in and it fans out locally (link-skills.sh) without any per-skill
# gitignore edit. The tracked .gitkeep both documents the convention and keeps
# the empty folder in git.
/skills/*
!/skills/.gitkeep
!/skills/brainstorming/
!/skills/brainstorming/**

# Remote-skill cache: content is materialized per-instance by resolve-skills.sh from
# root skills.toml and pinned by .skill-cache/skills.lock. Never committed — remote
# skills are referenced, not vendored.
/.skill-cache/

# Per-instance skill data: stateful skills persist local data here, outside their
# possibly-ephemeral skill dir. Never committed.
/.skill-data/
!/.skill-data/.gitkeep

# Your identity.md is per-instance, like config.local.sh and skills.toml. It was
# tracked until v1.0.0, which made it a trap: install.sh tells you to edit it, and
# sync-system.sh's dirty-tracked-file guard then aborts every sync. install.sh seeds
# it from the tracked templates/identity.template.md whenever it is missing.
/identity.md

# Your orchestrator.md is per-instance workflow doctrine. install.sh seeds it from
# templates/orchestrator.template.md whenever missing; edits are local like identity.md.
/orchestrator.md

# Stray terraform state from validator probes (echo-PWNED-style tests)
terraform.tfstate
terraform.tfstate.backup
.terraform/
