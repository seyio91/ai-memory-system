# config.local.sh — per-environment overrides for the memory system.
#
# Copy to config.local.sh (gitignored) and edit. Sourced by scripts/_lib.sh and
# scripts/taskctl when present, so these values reach scripts, hooks, and
# subagents that do NOT inherit your shell's rc files. Plain shell — use `export`
# so child processes (e.g. the Python task-provider) see them too.

# Root under which your code checkouts live. resolve_repo_path joins this with a
# project's `repo_path` frontmatter; the git-remote fallback scans repos here.
# export AI_MEMORY_PROJECTS_ROOT="$HOME/Projects"

# Task-provider backend: local (default) or notion. Notion also needs
# NOTION_TOKEN + NOTION_DATA_SOURCE_ID (and NOTION_STATUS_KIND=select if the
# Notion Status property is a select rather than a status type).
# export MEMORY_TASK_PROVIDER="local"

# Other tunables (uncomment to override their defaults):
# export MEMORY_STALE_DAYS=30            # lint-memory.sh working-memory age warning
# export MEMORY_ARCHIVE_RETAIN_DAYS=30   # archive-cleanup.sh retention threshold

# ── Orchestrator executor selection ──
# Which executor the orchestrator delegates actionable work to.
#   claude-subagent  — in-harness Claude Agent tool (default; always available)
#   codex            — CLI via scripts/codex-mem.sh --executor
#   <other>          — generic CLI; define its command with AI_MEMORY_EXECUTOR_CMD_<key>
#                      (<key> must match [A-Za-z0-9_]+; the template must contain {prompt})
# export AI_MEMORY_EXECUTOR="claude-subagent"

# Generic CLI executor example ({prompt} is substituted, already shell-quoted):
# export AI_MEMORY_EXECUTOR="aider"
# export AI_MEMORY_EXECUTOR_CMD_aider='aider --yes --message {prompt}'

# Fallback used when the preferred CLI executor's binary is missing.
# Empty string = hard-fail instead of falling back.
# export AI_MEMORY_EXECUTOR_FALLBACK="claude-subagent"

# NOTE: MEMORY_DIR cannot be set here — it must be known before this file is
# found. Relocate the memory tree via the MEMORY_DIR env var in your shell/env.
