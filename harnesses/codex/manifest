# Codex CLI — delivery + execute manifest.
# file archetype: materialize ~/.codex/AGENTS.md, rebuilt on each launch by the
# wrapper (harnesses/codex/scripts/codex-mem.sh); md format.
name           = codex
archetype      = file
format         = md
context_target = ~/.codex/AGENTS.md
refresh        = launch

# hybrid: file-archetype AGENTS.md base + native Codex hooks for the dynamic roles
hooks_json        = ~/.codex/hooks.json
hook_script       = $MEMORY_DIR/scripts/hooks/inject.sh
guard_script      = $MEMORY_DIR/scripts/hooks/guard.sh
arm_script        = $MEMORY_DIR/harnesses/codex/hooks/arm_recompact.sh
hooks_min_version = 0.135.0

# Forward-declared delivery surfaces. The generic per-manifest fan-out (skills
# into ~/.agents/skills; command bodies delivered AS skills) lands in Phase 4;
# the Phase-3 engine reports them deferred rather than wiring them.
skills_dir     = ~/.agents/skills
commands       = skill

# execute face: headless Codex via the memory wrapper (builds AGENTS.md + sandbox
# flags), so a delegated run sees fresh memory. {prompt}/{model} substituted by
# executor.sh; $MEMORY_DIR expanded. exec_probe gates availability on the codex bin.
exec_cmd        = $MEMORY_DIR/harnesses/codex/scripts/codex-mem.sh --executor {prompt}
exec_readonly   = $MEMORY_DIR/harnesses/codex/scripts/codex-mem.sh exec --dangerously-bypass-hook-trust --sandbox read-only {prompt}
exec_model_flag = --model {model}
# clean-output flag for `executor.sh --run --clean`: `codex exec -o <file>` writes ONLY the final
# agent message to <file>, so the caller gets a uniform, transcript-free result (probe-verified the
# flag parses after the positional prompt). {file} is substituted by executor.sh.
exec_last_message = -o {file}
exec_probe      = codex

[hooks]
per_turn_inject = UserPromptSubmit
infra_guard     = PreToolUse:^Bash$|apply_patch
compaction_arm  = SessionStart
