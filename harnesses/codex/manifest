# Codex CLI — delivery + execute manifest.
# file archetype: materialize ~/.codex/AGENTS.md, rebuilt on each launch by the
# wrapper (harnesses/codex/scripts/codex-mem.sh); md format.
name           = codex
archetype      = file
format         = md
context_target = ~/.codex/AGENTS.md
refresh        = launch

# Forward-declared delivery surfaces. The generic per-manifest fan-out (skills
# into ~/.agents/skills; command bodies delivered AS skills) lands in Phase 4;
# the Phase-3 engine reports them deferred rather than wiring them.
skills_dir     = ~/.agents/skills
commands       = skill

# execute face: headless Codex via the memory wrapper (builds AGENTS.md + sandbox
# flags), so a delegated run sees fresh memory. {prompt}/{model} substituted by
# executor.sh; $MEMORY_DIR expanded. exec_probe gates availability on the codex bin.
exec_cmd        = $MEMORY_DIR/harnesses/codex/scripts/codex-mem.sh --executor {prompt}
exec_readonly   = $MEMORY_DIR/harnesses/codex/scripts/codex-mem.sh exec --sandbox read-only {prompt}
exec_model_flag = --model {model}
exec_probe      = codex
