# Codex CLI — delivery + execute manifest.
# file archetype: ~/.codex/AGENTS.md is a hand-owned STATIC base (workflow rules +
# user overlay), never written by the memory system; the dynamic memory tree
# injects live via the SessionStart hook (refresh=hook), mirroring Antigravity. md
# format. The wrapper (harnesses/codex/scripts/codex-mem.sh) survives for the
# executor face only — sandbox flags, no file build.
name           = codex
archetype      = file
format         = md
context_target = ~/.codex/AGENTS.md
refresh        = hook

# hybrid: hand-owned AGENTS.md base + native Codex hooks for base + dynamic roles
hooks_json        = ~/.codex/hooks.json
hook_script       = $MEMORY_DIR/scripts/hooks/inject.sh
guard_script      = $MEMORY_DIR/scripts/hooks/guard.sh
session_script    = $MEMORY_DIR/scripts/hooks/session_start_memory.sh
hooks_min_version = 0.135.0
# Codex caps each hook additionalContext message at ~10KB; fan out ordered slices.
# 12 x <=9000B = ~108KB capacity; the live ai-memory base renders ~97KB (probe
# 2026-07-16). Overflow is loud (marker on the last slice), never silent.
session_chunks    = 12
inject_chunks     = 12

# Forward-declared delivery surfaces. The generic per-manifest fan-out (skills
# into ~/.agents/skills; command bodies delivered AS skills) lands in Phase 4;
# the Phase-3 engine reports them deferred rather than wiring them.
skills_dir     = ~/.agents/skills
commands       = skill

# execute face: headless Codex via the memory wrapper (sandbox/network flags, no
# file build), so a delegated run sees fresh memory via the SessionStart hook.
# {prompt}/{model} substituted by executor.sh; $MEMORY_DIR expanded. exec_probe
# gates availability on the codex bin.
exec_cmd        = $MEMORY_DIR/harnesses/codex/scripts/codex-mem.sh --executor {prompt}
exec_readonly   = $MEMORY_DIR/harnesses/codex/scripts/codex-mem.sh exec --dangerously-bypass-hook-trust --sandbox read-only {prompt}
exec_model_flag = --model {model}
# clean-output flag for `executor.sh --run --clean`: `codex exec -o <file>` writes ONLY the final
# agent message to <file>, so the caller gets a uniform, transcript-free result (probe-verified the
# flag parses after the positional prompt). {file} is substituted by executor.sh.
exec_last_message = -o {file}
exec_probe      = codex

[hooks]
per_turn_inject   = UserPromptSubmit
infra_guard       = PreToolUse:^Bash$|apply_patch
session_bootstrap = SessionStart
