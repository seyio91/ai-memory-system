{
  "_comment": "Reference shape only. install.sh now auto-merges these hook entries into ~/.claude/settings.json using absolute paths from the active MEMORY_DIR, preserving sibling settings keys. statusLine remains shown here as the runtime shape for the separately installed ~/.claude/statusline.sh.",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": "bash $MEMORY_DIR/harnesses/claude/hooks/session_start_memory.sh" }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          { "type": "command", "command": "env MEMORY_DIR=$MEMORY_DIR AI_MEMORY_HOOK_FORMAT=xml AI_MEMORY_HOOK_EVENT=UserPromptSubmit bash $MEMORY_DIR/scripts/hooks/inject.sh" }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "TaskCreate|TaskUpdate",
        "hooks": [
          { "type": "command", "command": "bash $MEMORY_DIR/harnesses/claude/hooks/block_task_tools.sh" }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "$HOME/.claude/statusline.sh",
    "padding": 0
  }
}
